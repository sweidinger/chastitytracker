	<string>Die App benötigt Kamerazugriff, um Fotos für Einträge aufzunehmen.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Die App benötigt Zugriff auf die Fotobibliothek, um Fotos für Einträge auszuwählen.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Die App kann Fotos in deiner Bibliothek speichern.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Die App benötigt Mikrofonzugriff für Videoaufnahmen.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Die App verwendet Face ID, um deine Daten zu schützen.</string>
</dict>
</plist>
